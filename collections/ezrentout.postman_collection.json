        },
        {
          "name": "Create an asset",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"\",\n  \"group_id\": 0,\n  \"location_id\": 0\n}" },
            "url": { "raw": "{{baseUrl}}/assets.api", "host": ["{{baseUrl}}"], "path": ["assets.api"] },
            "description": "Creates a new fixed asset."
