            "description": "Retrieves a single asset."
          }
        },
        {
          "name": "Update asset GPS coordinates",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"latitude\": 0,\n  \"longitude\": 0\n}" },
            "url": { "raw": "{{baseUrl}}/assets/:assetNum/gps_coordinates.api", "host": ["{{baseUrl}}"], "path": ["assets", ":assetNum", "gps_coordinates.api"], "variable": [{ "key": "assetNum", "value": "" }] },
            "description": "Updates an asset's GPS coordinates for location tracking."
          }
        }
      ]
    },
